# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Get your API token from https://marketapp.ws/api-token
MARKETAPP_API_TOKEN=your_marketapp_api_token_here

# Get from https://my.telegram.org - Required for MTProto gift data
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Your Telegram User ID for admin panel access
ADMIN_USER_ID=your_user_id_here

# MongoDB connection string (optional - falls back to in-memory)
MONGODB_URI=mongodb://localhost:27017/ifragmentbot
