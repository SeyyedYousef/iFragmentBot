{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"html": {
		"parser": {
			"interpolation": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error"
			},
			"complexity": {
				"noStaticOnlyClass": "off"
			},
			"suspicious": {
				"useIterableCallbackReturn": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.json",
				"**/*.html",
				"**/*.md",
				"**/*.txt",
				"**/*.template.html"
			],
			"linter": {
				"enabled": false
			},
			"formatter": {
				"enabled": false
			}
		}
	]
}
